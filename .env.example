NODE_ENV=production
PORT=3000
VITE_API_URL=/api
REDIS_URL=redis://:YOUR_PASSWORD@localhost:6379
PROJECT_PATH=/home/your-user/htdocs/your-domain.com.br
LOG_PATH=/home/your-user/htdocs/your-domain.com.br/logs
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
APP_BASE_URL=https://yourdomain.com

# ─── E-MAIL / MICROSOFT 365 (GRAPH API) ─────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
EMAIL_FROM_ADDRESS=atendimento@yourdomain.com
EMAIL_FROM_NAME=Nome do Hospital
EMAIL_SAC_ADDRESS=sac@yourdomain.com
EMAIL_LOGO_URL=https://yourdomain.com/img/logo.png
EMAIL_QUEUE_CONCURRENCY=5
EMAIL_QUEUE_RETRY_ATTEMPTS=3
EMAIL_QUEUE_RETRY_DELAY_MS=60000
EMAIL_DRY_RUN=false

# ─── RECAPTCHA V2 ────────────────────────────────────────────────────────
VITE_RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key
